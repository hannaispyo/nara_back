# ─── Supabase ───────────────────────────────────────────────
# Project Settings → API
SUPABASE_URL=https://xxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJ...            # publishable (se expone al navegador del admin)
SUPABASE_SERVICE_ROLE_KEY=eyJ...    # SECRETO — solo servidor, nunca al cliente

# Emails autorizados para entrar al /admin (coma-separados, en minúscula)
ADMIN_EMAILS=hanna@authomata.io

# ─── Instagram (opcional; activar cuando conectes la cuenta) ──
# Cuentas que administras vía Instagram Graph API (feed en vivo).
# Formato JSON: { "handle": { "userId": "...", "token": "..." }, ... }
IG_ACCOUNTS_JSON={}
