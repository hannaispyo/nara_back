# ─── Base de datos (Vercel Postgres) ────────────────────────
# Se inyecta AUTOMÁTICamente al conectar el store Postgres en el dashboard.
POSTGRES_URL=

# ─── Storage de imágenes (Vercel Blob) ──────────────────────
# Se inyecta AUTOMÁTICamente al crear el store Blob en el dashboard.
BLOB_READ_WRITE_TOKEN=

# ─── Auth del /admin (setear a mano) ────────────────────────
AUTH_SECRET=          # cadena aleatoria larga: openssl rand -base64 32
ADMIN_EMAIL=hanna@authomata.io
# Generá el hash con:  npm run hash-password -- 'tu-contraseña'
ADMIN_PASSWORD_HASH=  # formato scrypt$<salt>$<hash>

# ─── Instagram (opcional) ───────────────────────────────────
# { "handle": { "userId": "...", "token": "..." }, ... }
IG_ACCOUNTS_JSON={}
